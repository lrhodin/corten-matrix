#!/usr/bin/env bash
# ============================================================================
# imessage — host-side CLI for the mautrix-imessage-v2 Docker bridge.
#
# Install once (one line, always on PATH):
#   curl -L https://raw.githubusercontent.com/lrhodin/imessage/master/scripts/imessage \
#     | sudo install /dev/stdin /usr/local/bin/imessage
#
# To update later: re-run the same command.
# To uninstall:    sudo rm /usr/local/bin/imessage
#
# All subcommands work from any directory. Compose-driven subcommands
# (start / stop / restart / update / pull) need to know where your
# docker-compose.yml lives — set IMESSAGE_COMPOSE_FILE, or run from the
# directory containing it.
# ============================================================================
set -euo pipefail

CONTAINER="${IMESSAGE_CONTAINER:-Rustpush-Matrix}"
COMPOSE_FILE="${IMESSAGE_COMPOSE_FILE:-}"

# Marker block format matches the bare-Linux install scripts so migrating
# in either direction never produces duplicates. Keep this string in sync
# with scripts/install-beeper-linux.sh and scripts/install-linux.sh.
MARKER_START="# >>> mautrix-imessage shortcuts (managed) >>>"
MARKER_END="# <<< mautrix-imessage shortcuts (managed) <<<"

usage() {
    cat <<'EOF'
imessage — host-side CLI for the mautrix-imessage-v2 Docker bridge.

USAGE
    imessage <command> [args...]

Every subcommand is a thin wrapper around the raw command shown after the
arrow. Useful when debugging or when you want to run the underlying
operation manually.

DAILY (work from any directory — container looked up by name)
    setup           → docker exec -it Rustpush-Matrix imessage-setup
                      Interactive setup wizard inside the container.
    login           → docker exec -it Rustpush-Matrix /entrypoint.sh login
                      Re-run only the iMessage login flow.
    logs            → tail -F <host bind-mount>/logs/bridge.log
                      Live-watch the bridge's full zerolog file directly
                      on the host volume. Works whether the container
                      is running, restart-looping, or stopped — the
                      file persists on the bind mount regardless.
    status          → docker ps --filter name=^Rustpush-Matrix$
                      Is the container running?
    shell           → docker exec -it Rustpush-Matrix bash
                      Open a debug shell inside the container.
    bbctl <args>    → docker exec -it Rustpush-Matrix bbctl <args>
                      Run the Beeper bridge-manager CLI inside the container.
                      e.g. `imessage bbctl whoami`, `imessage bbctl logout`.

LIFECYCLE (must run from the directory with docker-compose.yml — or set IMESSAGE_COMPOSE_FILE)
    start           → docker compose up -d
                      Automatically verifies bind-mount permissions match
                      the container's user: directive; corrects them if needed
                      with verbose console output.
    stop            → docker compose stop Rustpush-Matrix
    restart         → docker compose restart Rustpush-Matrix
    pull            → docker compose pull
    update          → docker compose pull && docker compose up -d
    fix-perms       Diagnostic: read the bind mount + user: from your
                    compose file and report permissions without changing
                    them. Useful for troubleshooting permission mismatches.

OTHER
    help, -h, --help    Print this message.

ENV
    IMESSAGE_CONTAINER      Container name (default: Rustpush-Matrix).
    IMESSAGE_COMPOSE_FILE   Path to docker-compose.yml for lifecycle commands.
                            Otherwise compose looks in the current dir.

Examples
    imessage setup
    imessage logs
    imessage bbctl whoami
    IMESSAGE_COMPOSE_FILE=~/docker/imessage/docker-compose.yml imessage update
EOF
}

# ── helpers ─────────────────────────────────────────────────────────────────

# compose() — invoke docker compose with the user's compose file if set.
compose() {
    if [ -n "$COMPOSE_FILE" ]; then
        docker compose -f "$COMPOSE_FILE" "$@"
    else
        docker compose "$@"
    fi
}

require_python3() {
    if ! command -v python3 >/dev/null 2>&1; then
        echo "error: python3 is required to parse docker compose output." >&2
        echo "  Install it: apt install python3   (or your distro's equivalent)" >&2
        exit 1
    fi
}

render_compose_mounts() {
    # Print tab-separated rows:
    #   USER <uid:gid>
    #   BIND <host source> <container target>
    #
    # Use rendered compose JSON instead of scraping YAML so both short-form
    # and long-form bind mounts work the same way.
    require_python3
    compose config --format json | python3 -c '
import sys, json
cfg = json.load(sys.stdin)
services = cfg.get("services", {})
svc = services.get("Rustpush-Matrix") or next(iter(services.values()), {})
user = str(svc.get("user") or "1000:1000")
if ":" not in user:
    user = f"{user}:{user}"
print(f"USER\t{user}")
for v in svc.get("volumes", []) or []:
    if isinstance(v, dict) and v.get("type") == "bind":
        src = v.get("source", "")
        dst = v.get("target", "")
        if src:
            print(f"BIND\t{src}\t{dst}")
'
}

run_root_cmd() {
    if [ "$(id -u)" = "0" ]; then
        "$@"
    elif command -v sudo >/dev/null 2>&1; then
        sudo "$@"
    else
        echo "error: need root privileges to run: $*" >&2
        echo "  Re-run as root or install sudo." >&2
        exit 1
    fi
}

check_bind_mount_perms() {
    local parsed="$1"
    local target_user="$2"
    local mode="${3:-auto}"

    while IFS=$'\t' read -r kind src dst; do
        [ "$kind" = "BIND" ] || continue
        [ -n "$src" ] || continue

        if [ ! -d "$src" ]; then
            if [ "$mode" = "dry-run" ]; then
                echo "    create $src"
            else
                echo "[startup] creating $src"
                run_root_cmd mkdir -p "$src"
            fi
        fi

        if [ -d "$src" ]; then
            if [ "$mode" = "dry-run" ]; then
                if [ "$(id -u)" = "0" ]; then
                    echo "    chown -R $target_user $src"
                else
                    echo "    sudo chown -R $target_user $src"
                fi
            else
                echo "[startup] fixing perms: $src → $target_user"
                run_root_cmd chown -R "$target_user" "$src"
            fi
        elif [ "$mode" != "dry-run" ]; then
            echo "error: failed to create bind-mount source: $src" >&2
            exit 1
        fi
    done <<<"$parsed"
}

# detect_rc_files() — print paths to host shell rc files that exist.
# Same heuristic the bare-Linux installer uses (case "$SHELL"), but we
# return all matching files because users may have both.
detect_rc_files() {
    local files=()
    case "${SHELL:-}" in
        */zsh)  [ -f "$HOME/.zshrc" ] && files+=("$HOME/.zshrc") ;;
        */bash) [ -f "$HOME/.bashrc" ] && files+=("$HOME/.bashrc") ;;
        *)
            # Unknown shell — fall back to whichever rc files exist.
            [ -f "$HOME/.bashrc" ] && files+=("$HOME/.bashrc")
            [ -f "$HOME/.zshrc" ] && files+=("$HOME/.zshrc")
            ;;
    esac
    printf '%s\n' "${files[@]}"
}

# strip_marker_block <rc-file>
# Safe to re-run: returns 0 if anything was stripped, 1 otherwise.
strip_marker_block() {
    local rc="$1"
    if [ -f "$rc" ] && grep -qF "$MARKER_START" "$rc"; then
        awk -v s="$MARKER_START" -v e="$MARKER_END" '
            $0 == s { skip = 1; next }
            $0 == e { skip = 0; next }
            !skip   { print }
        ' "$rc" > "$rc.tmp" && mv "$rc.tmp" "$rc"
        return 0
    fi
    return 1
}

# ── commands ────────────────────────────────────────────────────────────────

cmd_setup()   { exec docker exec -it "$CONTAINER" imessage-setup "$@"; }
cmd_login()   { exec docker exec -it "$CONTAINER" /entrypoint.sh login "$@"; }
cmd_logs()    {
    # Live-tail the bridge's zerolog file. When the container is running
    # we tail from inside it via `docker exec`, because tail-F on the
    # host side of a Docker bind mount has unreliable inotify behaviour
    # (writes from the container don't always wake up host-side
    # watchers). When the container is stopped or restart-looping,
    # docker exec can't attach, so we fall back to reading the same
    # file from the host bind-mount path — the file persists either
    # way, you just lose live-follow until the container's back up.
    local state
    state=$(docker inspect --format '{{.State.Status}}' "$CONTAINER" 2>/dev/null || echo missing)
    case "$state" in
        running)
            exec docker exec -it "$CONTAINER" tail -F /data/logs/bridge.log
            ;;
        missing)
            echo "error: container '$CONTAINER' doesn't exist. Did you 'imessage start' yet?" >&2
            exit 1
            ;;
        *)
            local host_path
            host_path=$(docker inspect --format '{{range .Mounts}}{{if eq .Destination "/data"}}{{.Source}}{{end}}{{end}}' "$CONTAINER" 2>/dev/null || true)
            if [ -z "$host_path" ]; then
                echo "error: no /data mount found on container '$CONTAINER'." >&2
                exit 1
            fi
            echo "(container is $state — tailing host bind-mount file; live-follow may be sluggish)" >&2
            exec tail -F "$host_path/logs/bridge.log"
            ;;
    esac
}
cmd_shell()   { exec docker exec -it "$CONTAINER" bash; }
cmd_status()  { docker ps --filter "name=^${CONTAINER}$" --format 'table {{.Names}}\t{{.Status}}\t{{.Image}}'; }
cmd_bbctl()   { exec docker exec -it "$CONTAINER" bbctl "$@"; }

cmd_fix_perms() {
    # Read the bind-mount source and target UID:GID directly from the
    # compose file (NOT from a running container — fix-perms has to work
    # before the first `imessage start`). Same compose-dir rule as
    # start/stop/restart: must run from the directory with your
    # docker-compose.yml or set IMESSAGE_COMPOSE_FILE.
    if [ ! -t 0 ] || [ ! -t 1 ]; then
        echo "error: fix-perms is interactive; run from a real terminal." >&2
        exit 2
    fi

    # Verify we can render the compose file from here.
    if ! compose config --format json >/dev/null 2>&1; then
        cat >&2 <<EOF
error: docker compose can't render a compose file from here.

fix-perms reads the bind mount + user from your compose project —
same CWD rule as 'imessage start'. cd to the directory containing
docker-compose.yml, or set IMESSAGE_COMPOSE_FILE to its absolute path.
EOF
        exit 1
    fi

    # Pull ALL bind-mount sources and the container user out of the
    # rendered compose JSON. The compose example has two: /data
    # (bridge state) and /home/bridge/.config/bbctl (bbctl
    # auth). Both need to be writable by the container's UID:GID.
    local parsed
    parsed=$(render_compose_mounts) || { echo "error: failed to parse compose config" >&2; exit 1; }

    local user_dir
    user_dir=$(printf '%s\n' "$parsed" | awk -F '\t' '$1=="USER"{print $2}')
    if ! printf '%s' "$user_dir" | grep -qE '^[0-9]+:[0-9]+$'; then
        echo "error: 'user: $user_dir' in compose isn't numeric UID:GID." >&2
        echo "  Set PUID and PGID to numeric values, e.g. PUID=1000 and PGID=1000." >&2
        exit 1
    fi

    # Collect each bind mount source + its container destination.
    local binds
    binds=$(printf '%s\n' "$parsed" | awk -F '\t' '$1=="BIND"{print $2 "\t" $3}')
    if [ -z "$binds" ]; then
        echo "error: no bind mounts found in compose." >&2
        exit 1
    fi

    echo ""
    echo "Read from your compose project:"
    echo "    container user: $user_dir"
    echo "    bind mounts:"
    while IFS=$'\t' read -r src dst; do
        [ -z "$src" ] && continue
        printf '        %-50s → %s\n' "$src" "$dst"
    done <<<"$binds"

    echo ""
    echo "About to chown each bind-mount source to $user_dir (recursively):"
    check_bind_mount_perms "$parsed" "$user_dir" dry-run

    local yn
    read -r -p "Proceed? [y/N]: " yn
    case "$yn" in
        [yY]|[yY][eE][sS]) ;;
        *) echo "Aborted."; exit 0 ;;
    esac

    check_bind_mount_perms "$parsed" "$user_dir" auto

    echo ""
    echo "✓ Done. You can now run 'imessage start' (or 'imessage restart' if already up)."
}

cmd_start() {
    # Check and fix bind-mount permissions before starting.
    echo "[startup] checking bind-mount permissions..."

    if ! compose config --format json >/dev/null 2>&1; then
        cat >&2 <<EOF
error: docker compose can't render a compose file from here.

start reads bind mounts from your compose project before starting.
cd to the directory containing docker-compose.yml, or set
IMESSAGE_COMPOSE_FILE to its absolute path.
EOF
        exit 1
    fi

    local parsed target_user
    parsed=$(render_compose_mounts) || { echo "error: failed to parse compose config" >&2; exit 1; }
    target_user=$(printf '%s\n' "$parsed" | awk -F '\t' '$1=="USER"{print $2}')
    if ! printf '%s' "$target_user" | grep -qE '^[0-9]+:[0-9]+$'; then
        echo "error: 'user: $target_user' in compose isn't numeric UID:GID." >&2
        echo "  Set PUID and PGID to numeric values, e.g. PUID=1000 and PGID=1000." >&2
        exit 1
    fi

    check_bind_mount_perms "$parsed" "$target_user" auto

    echo "[startup] starting container..."
    compose up -d
}
cmd_stop()    { compose stop "$CONTAINER"; }
cmd_restart() { compose restart "$CONTAINER"; }
cmd_pull()    { compose pull; }
cmd_update()  { compose pull && compose up -d; }


# ── dispatch ────────────────────────────────────────────────────────────────

cmd="${1:-}"
[ -n "$cmd" ] && shift || true

case "$cmd" in
    setup)              cmd_setup "$@" ;;
    login)              cmd_login "$@" ;;
    logs)               cmd_logs "$@" ;;
    shell)              cmd_shell "$@" ;;
    status)             cmd_status "$@" ;;
    bbctl)              cmd_bbctl "$@" ;;
    start)              cmd_start "$@" ;;
    stop)               cmd_stop "$@" ;;
    restart)            cmd_restart "$@" ;;
    pull)               cmd_pull "$@" ;;
    update)             cmd_update "$@" ;;
    fix-perms)          cmd_fix_perms "$@" ;;
    ""|help|-h|--help)  usage ;;
    *)                  echo "error: unknown command '$cmd'" >&2; usage >&2; exit 2 ;;
esac
